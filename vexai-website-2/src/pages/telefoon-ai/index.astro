---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Telefoon AI | AI-Receptionist die 24/7 Telefoon Opneemt | Vexai"
  description="Vexai's Telefoon AI neemt elk gesprek aan, plant direct afspraken in en koppelt aan je CRM. Geen gemiste oproepen meer. Menselijke stem, 24/7 actief."
  bodyBg="#F7F7F5"
>

  <style is:inline>
    body { background-color: #F7F7F5; color: #111111; }
    .text-secondary-auralis { color: #6B6B6B; }
    .bg-panel-auralis { background-color: #F3F2EF; }
    .bg-card-auralis { background-color: #FCFCFB; }
    .border-auralis { border-color: #E7E7E4; }
    .tel-h1 { font-size: 84px; line-height: 1.05; letter-spacing: -0.04em; font-weight: 600; font-family: 'Geist', sans-serif; }
    .tel-h2 { font-size: 64px; line-height: 1.1; letter-spacing: -0.03em; font-weight: 600; font-family: 'Geist', sans-serif; }
    .tel-h3 { font-size: 32px; line-height: 1.2; letter-spacing: -0.02em; font-weight: 600; font-family: 'Geist', sans-serif; }
    @media (max-width: 767px) {
      .tel-h1 { font-size: 38px; }
      .tel-h2 { font-size: 28px; }
      .tel-h3 { font-size: 22px; }
    }
  </style>

  <main class="flex-grow pt-[100px] md:pt-[140px] pb-12 antialiased overflow-x-hidden font-body-md text-body-md">

    <!-- HERO -->
    <section class="max-w-[1280px] mx-auto px-5 md:px-8 mb-[80px] md:mb-[140px]">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8 items-start">
        <div class="lg:col-span-7 flex flex-col gap-6 md:gap-8">
          <h1 class="tel-h1 text-primary" data-i18n="tel.h1">Een stem die er altijd is en altijd luistert</h1>
          <div class="flex flex-wrap items-center gap-3 md:gap-4">
            <a class="bg-primary text-on-primary px-6 py-3 rounded-full font-medium transition-all hover:opacity-90" href="/contact/" data-i18n="nav.cta">Plan een adviesgesprek</a>
            <a class="bg-transparent border border-outline text-primary px-6 py-3 rounded-full font-medium transition-all hover:bg-surface-variant" href="/contact/" data-i18n="nav.contact">Contact</a>
          </div>
        </div>
        <div class="lg:col-span-4 lg:col-start-9">
          <p class="font-body-lg text-body-lg text-secondary-auralis pt-0 md:pt-4" data-i18n="tel.hero_p">
            Zorg dat klanten nooit meer in een wachtrij belanden en er geen oproep meer gemist wordt. Ontdek de kracht van intelligente stemtechnologie waarbij de focus ligt op verbinden, niet alleen op reageren.
          </p>
        </div>
      </div>
    </section>

    <!-- HERO PRODUCT PANEL -->
    <section class="max-w-[1280px] mx-auto px-5 md:px-8 mb-[100px] md:mb-[180px]">
      <div class="bg-panel-auralis rounded-2xl md:rounded-3xl p-5 md:p-8 flex flex-col relative overflow-hidden border border-auralis min-h-[480px] md:min-h-[600px]" style="justify-content:space-between;">
        <!-- Top Tabs -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 z-10">
          <div class="flex bg-surface-container-low p-1 rounded-full border border-auralis shadow-sm">
            <button class="px-3 md:px-4 py-2 bg-surface text-primary rounded-full text-sm font-medium shadow-sm">Inbound Agent</button>
            <button class="px-3 md:px-4 py-2 text-secondary-auralis rounded-full text-sm font-medium hover:text-primary transition-colors">Outbound Agent</button>
          </div>
          <div class="bg-surface-container-low px-3 md:px-4 py-2 rounded-full border border-auralis flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            <span class="text-sm font-medium">Slimme stemtechnologie</span>
          </div>
        </div>
        <!-- Orb backgrounds -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-100">
          <div class="w-[200px] md:w-[300px] h-[200px] md:h-[300px] rounded-full bg-gradient-to-tr from-rose-400 to-orange-300 blur-3xl absolute -ml-40"></div>
          <div class="w-[280px] md:w-[400px] h-[280px] md:h-[400px] rounded-full bg-gradient-to-tr from-indigo-300 to-purple-400 blur-3xl absolute"></div>
          <div class="w-[180px] md:w-[250px] h-[180px] md:h-[250px] rounded-full bg-gradient-to-tr from-emerald-300 to-teal-200 blur-3xl absolute ml-40 mt-20"></div>
          <div class="w-[240px] md:w-[350px] h-[240px] md:h-[350px] rounded-full bg-gradient-to-tr from-sky-300 to-blue-400 blur-3xl absolute ml-80 -mt-20"></div>
        </div>
        <!-- Play button -->
        <div class="z-10 self-center my-auto flex flex-col items-center gap-4">
          <audio id="inboundAudio" preload="none">
            <source src="https://pub-6d418d1898fb4219bf2227841c588d5e.r2.dev/AI%20VOICE%20GESPREK%20TOPCHIRO%20-%2009-03-2026%2C%2012.43.mp3" type="audio/mpeg" />
          </audio>
          <button
            id="inboundPlayBtn"
            class="w-16 h-16 md:w-20 md:h-20 bg-surface rounded-full flex items-center justify-center shadow-lg border border-auralis transition-transform hover:scale-105 group"
            aria-label="Afspelen"
          >
            <span id="inboundIcon" class="material-symbols-outlined text-3xl md:text-4xl text-primary pl-1 group-hover:text-emerald-600 transition-colors">play_arrow</span>
          </button>
        </div>
        <script is:inline>
          (function() {
            var btn  = document.getElementById('inboundPlayBtn');
            var audio = document.getElementById('inboundAudio');
            var icon = document.getElementById('inboundIcon');
            if (!btn || !audio || !icon) return;
            btn.addEventListener('click', function() {
              if (audio.paused) {
                audio.play();
                icon.textContent = 'pause';
                icon.style.paddingLeft = '0';
              } else {
                audio.pause();
                icon.textContent = 'play_arrow';
                icon.style.paddingLeft = '4px';
              }
            });
            audio.addEventListener('ended', function() {
              icon.textContent = 'play_arrow';
              icon.style.paddingLeft = '4px';
              audio.currentTime = 0;
            });
            audio.addEventListener('error', function() {
              icon.textContent = 'error_outline';
              icon.style.paddingLeft = '0';
              btn.disabled = true;
              btn.style.opacity = '0.4';
              btn.title = 'Audio kon niet worden geladen';
            });
          })();
        </script>
        <!-- Bottom bar -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 z-10 bg-surface/80 backdrop-blur-md p-3 md:p-4 rounded-xl md:rounded-2xl border border-auralis">
          <div class="flex flex-wrap gap-3 md:gap-6">
            <span class="text-sm font-medium text-secondary-auralis"><strong>Natuurlijke Intonatie</strong>&nbsp;&nbsp;Contextueel begrip</span>
            <span class="text-sm font-medium text-secondary-auralis">Directe CRM-koppeling</span>
            <span class="hidden sm:inline text-sm font-medium text-secondary-auralis">Geen vertraging</span>
            <span class="hidden sm:inline text-sm font-medium text-secondary-auralis">Meertalig</span>
          </div>
          <a class="bg-primary text-on-primary px-5 py-2 rounded-full text-sm font-medium whitespace-nowrap flex-shrink-0" href="/contact/">Kom in contact</a>
        </div>
      </div>
    </section>

    <!-- LOGO MARQUEE -->
    <section class="w-full bg-[#f9f9f9] py-12 md:py-16 mb-[80px] md:mb-[140px] overflow-hidden relative">
      <div class="max-w-[1280px] mx-auto px-5 md:px-8 mb-8 md:mb-12 text-center">
        <h4 class="text-xs font-semibold tracking-widest text-zinc-400 uppercase" data-i18n="tel.marquee_label">Integreert naadloos met jouw CRM- en DMS-systemen</h4>
      </div>
      <div class="relative flex overflow-hidden">
        <div class="absolute inset-y-0 left-0 w-16 md:w-32 bg-gradient-to-r from-[#f9f9f9] to-transparent z-10 pointer-events-none"></div>
        <div class="absolute inset-y-0 right-0 w-16 md:w-32 bg-gradient-to-l from-[#f9f9f9] to-transparent z-10 pointer-events-none"></div>
        <div class="flex animate-marquee whitespace-nowrap gap-16 md:gap-24 items-center">
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">Salesforce</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">HubSpot</div>
          <div class="flex items-center gap-2 text-slate-800 opacity-80 font-semibold text-base md:text-lg"><span class="material-symbols-outlined">grid_view</span> Microsoft Dynamics 365</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">Zoho CRM</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">Autoline</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">CarSy</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">AFAS</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">Exact</div>
          <div class="flex items-center gap-2 text-slate-800 opacity-80 font-semibold text-base md:text-lg"><span class="material-symbols-outlined">mail</span> Gmail</div>
          <div class="flex items-center gap-2 text-slate-800 opacity-80 font-semibold text-base md:text-lg"><span class="material-symbols-outlined">calendar_today</span> Google Calendar</div>
          <div class="flex items-center gap-2 text-slate-800 opacity-80 font-semibold text-base md:text-lg"><span class="material-symbols-outlined">alternate_email</span> Microsoft Outlook</div>
          <!-- Duplicate for seamless loop -->
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">Salesforce</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">HubSpot</div>
          <div class="flex items-center gap-2 text-slate-800 opacity-80 font-semibold text-base md:text-lg"><span class="material-symbols-outlined">grid_view</span> Microsoft Dynamics 365</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">Zoho CRM</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">Autoline</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">CarSy</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">AFAS</div>
          <div class="flex items-center gap-3 text-slate-800 opacity-80 font-bold italic text-lg md:text-xl">Exact</div>
          <div class="flex items-center gap-2 text-slate-800 opacity-80 font-semibold text-base md:text-lg"><span class="material-symbols-outlined">mail</span> Gmail</div>
          <div class="flex items-center gap-2 text-slate-800 opacity-80 font-semibold text-base md:text-lg"><span class="material-symbols-outlined">calendar_today</span> Google Calendar</div>
          <div class="flex items-center gap-2 text-slate-800 opacity-80 font-semibold text-base md:text-lg"><span class="material-symbols-outlined">alternate_email</span> Microsoft Outlook</div>
        </div>
      </div>
    </section>

    <!-- PLATFORM OVERVIEW -->
    <section class="max-w-[1280px] mx-auto px-5 md:px-8 mb-[100px] md:mb-[180px]">
      <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
        <h2 class="tel-h2 text-primary mb-6" data-i18n="tel.platform_h2">Twee systemen, één centrale intelligentie</h2>
        <p class="font-body-lg text-body-lg text-secondary-auralis" data-i18n="tel.platform_p">Of het nu gaat om inkomende vragen of proactieve opvolging; beide krachten putten uit exact dezelfde basis. De AI begrijpt je bedrijf door en door, communiceert met je CRM en zorgt voor een consistente, hoogwaardige ervaring in elk gesprek.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mb-8 md:mb-12">
        <div class="bg-card-auralis rounded-2xl p-6 border border-auralis min-h-[200px] md:h-[300px] flex flex-col justify-between relative overflow-hidden group hover:shadow-sm transition-shadow">
          <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-purple-500/20 opacity-40 group-hover:opacity-60 transition-opacity"></div>
          <div class="z-10">
            <h4 class="font-h3 text-[20px] mb-2" data-i18n="tel.inbound_h">Inbound</h4>
            <p class="text-sm text-secondary-auralis" data-i18n="tel.inbound_p">Elk inkomend gesprek direct en professioneel opgevangen. De AI begrijpt de intentie van de klant, biedt de juiste service en zorgt voor een vloeiende overgang naar je team waar nodig is.</p>
          </div>
        </div>
        <div class="bg-card-auralis rounded-2xl p-6 border border-auralis min-h-[200px] md:h-[300px] flex flex-col justify-between relative overflow-hidden group hover:shadow-sm transition-shadow">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 to-teal-500/20 opacity-40 group-hover:opacity-60 transition-opacity"></div>
          <div class="z-10">
            <h4 class="font-h3 text-[20px] mb-2" data-i18n="tel.outbound_h">Outbound</h4>
            <p class="text-sm text-secondary-auralis" data-i18n="tel.outbound_p">Proactief contact met je leads zonder zelf te hoeven bellen. Het systeem belt binnen 5 minuten na een aanvraag of reactiveert oude lijsten, zodat er nooit meer een waardevolle kans blijft liggen.</p>
          </div>
        </div>
      </div>
      <!-- Dashboard panel -->
      <div class="w-full aspect-[16/9] bg-panel-auralis rounded-2xl md:rounded-3xl border border-auralis flex items-center justify-center overflow-hidden relative">
        <div class="absolute inset-0 flex items-center justify-center z-20">
          <div class="absolute w-64 h-64 bg-blue-500/20 rounded-full blur-[80px] -translate-x-20 -translate-y-10"></div>
          <div class="absolute w-64 h-64 bg-purple-500/20 rounded-full blur-[80px] translate-x-20 translate-y-10"></div>
          <div class="relative w-[280px] md:w-[440px] bg-white/25 backdrop-blur-3xl border border-white/40 rounded-[1.5rem] md:rounded-[2rem] p-5 md:p-8 shadow-[0_48px_96px_-24px_rgba(0,0,0,0.25),inset_0_0_0_1px_rgba(255,255,255,0.4)] flex flex-col gap-5 md:gap-8">
            <div class="flex items-center justify-between">
              <div class="flex flex-col">
                <span class="text-[10px] md:text-[11px] font-bold uppercase tracking-[0.25em] text-primary/50 mb-1">_Vexai AI-Engine V4.2 Pro</span>
                <span class="text-xs md:text-sm font-semibold text-primary tracking-tight">Realtime AI-Gesprekshub</span>
              </div>
              <div class="flex items-center gap-2 bg-emerald-500/15 px-2.5 py-1 rounded-full border border-emerald-500/25">
                <div class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                <span class="text-[9px] md:text-[10px] font-bold text-emerald-700 uppercase tracking-widest">Live</span>
              </div>
            </div>
            <div class="flex items-end justify-between h-16 md:h-24 gap-1">
              <div class="w-1.5 bg-gradient-to-t from-blue-500/40 to-blue-500 rounded-full h-[25%]"></div>
              <div class="w-1.5 bg-gradient-to-t from-blue-500/40 to-blue-500 rounded-full h-[40%]"></div>
              <div class="w-1.5 bg-gradient-to-t from-blue-500/40 to-blue-500 rounded-full h-[65%]"></div>
              <div class="w-1.5 bg-gradient-to-t from-blue-500/40 to-blue-500 rounded-full h-[55%]"></div>
              <div class="w-1.5 bg-gradient-to-t from-purple-500/40 to-purple-600 rounded-full h-[85%]"></div>
              <div class="w-1.5 bg-gradient-to-t from-purple-500/40 to-purple-600 rounded-full h-[95%]"></div>
              <div class="w-1.5 bg-gradient-to-t from-purple-500/40 to-purple-600 rounded-full h-[70%]"></div>
              <div class="w-1.5 bg-gradient-to-t from-blue-500/40 to-blue-500 rounded-full h-[45%]"></div>
              <div class="w-1.5 bg-gradient-to-t from-blue-500/40 to-blue-500 rounded-full h-[60%]"></div>
              <div class="w-1.5 bg-gradient-to-t from-blue-500/40 to-blue-500 rounded-full h-[30%]"></div>
            </div>
            <div class="grid grid-cols-3 gap-3 md:gap-6 py-1 md:py-2">
              <div class="flex flex-col gap-1">
                <span class="text-[9px] md:text-[10px] uppercase tracking-widest text-secondary-auralis font-semibold">Reactietijd</span>
                <div class="flex items-baseline gap-1"><span class="text-base md:text-xl font-bold text-primary">24</span><span class="text-[10px] md:text-xs text-secondary-auralis font-medium">ms</span></div>
              </div>
              <div class="flex flex-col gap-1">
                <span class="text-[9px] md:text-[10px] uppercase tracking-widest text-secondary-auralis font-semibold">Nauwkeurigheid</span>
                <div class="flex items-baseline gap-1"><span class="text-base md:text-xl font-bold text-primary">99.8</span><span class="text-[10px] md:text-xs text-secondary-auralis font-medium">%</span></div>
              </div>
              <div class="flex flex-col gap-1">
                <span class="text-[9px] md:text-[10px] uppercase tracking-widest text-secondary-auralis font-semibold">Stabiliteit</span>
                <div class="flex items-baseline gap-1"><span class="text-base md:text-xl font-bold text-primary">0.02</span><span class="text-[10px] md:text-xs text-secondary-auralis font-medium">jitter</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- STUDIO MODULE -->
    <section class="max-w-[1280px] mx-auto px-5 md:px-8 mb-[100px] md:mb-[180px]">
      <div class="flex items-center gap-4 mb-6 md:mb-8">
        <span class="font-label-caps text-label-caps bg-surface-variant text-primary px-3 py-1 rounded-full">_Vexai Studio</span>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-12 mb-8 md:mb-12">
        <div class="lg:col-span-5">
          <h2 class="tel-h2 text-primary leading-tight" data-i18n="tel.studio_h2">Slimme functies die je workflow versterken</h2>
        </div>
        <div class="lg:col-span-6 lg:col-start-7 flex items-end">
          <p class="font-body-lg text-body-lg text-secondary-auralis" data-i18n="tel.studio_p">Achter elke succesvolle oproep staat een netwerk van geavanceerde technologische functies</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 mb-5 md:mb-6">
        <div class="bg-card-auralis rounded-2xl p-5 md:p-6 border border-auralis min-h-[200px] md:h-[300px] flex flex-col justify-between relative overflow-hidden group hover:shadow-sm transition-shadow">
          <div class="flex justify-between items-start z-10">
            <span class="material-symbols-outlined text-secondary-auralis">edit_document</span>
          </div>
          <div class="z-10">
            <h4 class="font-h3 text-[18px] md:text-[20px] mb-2" data-i18n="tel.agenda_h">Directe agenda-koppeling</h4>
            <p class="text-sm text-secondary-auralis" data-i18n="tel.agenda_p">Zodra de AI een positieve reactie ontvangt, wordt er direct een afspraak ingeschoten. Het systeem kijkt realtime in je agenda, stelt beschikbare tijden voor en legt de datum vast zonder dat er een medewerker aan te pas komt.</p>
          </div>
        </div>
        <div class="bg-card-auralis rounded-2xl p-5 md:p-6 border border-auralis min-h-[200px] md:h-[300px] flex flex-col justify-between relative overflow-hidden group hover:shadow-sm transition-shadow">
          <div class="flex justify-between items-start z-10">
            <span class="material-symbols-outlined text-secondary-auralis">closed_caption</span>
          </div>
          <div class="z-10">
            <h4 class="font-h3 text-[18px] md:text-[20px] mb-2" data-i18n="tel.reports_h">Automatische verslagen</h4>
            <p class="text-sm text-secondary-auralis" data-i18n="tel.reports_p">Elk gesprek wordt realtime omgezet in tekst en samengevat door de AI. Belangrijke data, klantbehoeften en gemaakte afspraken worden direct gefilterd, zodat je team direct over de juiste context beschikt.</p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        <div class="bg-panel-auralis rounded-xl p-4 md:p-5 border border-auralis flex flex-col gap-3 items-start hover:bg-surface-variant/50 transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-primary">music_note</span>
          <span class="font-medium text-sm">Gespreksdynamiek</span>
        </div>
        <div class="bg-panel-auralis rounded-xl p-4 md:p-5 border border-auralis flex flex-col gap-3 items-start hover:bg-surface-variant/50 transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-primary">graphic_eq</span>
          <span class="font-medium text-sm">Slimme filtering</span>
        </div>
        <div class="bg-panel-auralis rounded-xl p-4 md:p-5 border border-auralis flex flex-col gap-3 items-start hover:bg-surface-variant/50 transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-primary">record_voice_over</span>
          <span class="font-medium text-sm">Slimme data-analyse</span>
        </div>
        <div class="bg-panel-auralis rounded-xl p-4 md:p-5 border border-auralis flex flex-col gap-3 items-start hover:bg-surface-variant/50 transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-primary">movie</span>
          <span class="font-medium text-sm">SMS en E-mail triggers</span>
        </div>
      </div>
    </section>

    <!-- SIGN OFF -->
    <section class="max-w-[1280px] mx-auto px-5 md:px-8 mb-[80px] md:mb-[140px] text-center flex flex-col items-center w-full">
      <h2 class="tel-h2 text-primary mb-6 md:mb-8 font-bold" data-i18n="tel.final_h2">De nieuwe standaard voor menselijk klantcontact</h2>
      <a class="bg-primary text-on-primary px-6 py-3 rounded-full font-medium transition-all hover:opacity-90" href="/contact/" data-i18n="tel.final_btn">Begin nu met _Vexai</a>
    </section>

  </main>
</Layout>
