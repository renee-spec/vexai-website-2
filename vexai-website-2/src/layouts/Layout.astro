    var lang = (typeof localStorage !== 'undefined' && localStorage.getItem('vexai_lang')) || 'nl';

    function applyLang(l) {
      lang = l;
      if (typeof localStorage !== 'undefined') localStorage.setItem('vexai_lang', l);
      var t = T[l];
      if (!t) return;

      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n');
        if (t[key] !== undefined) el.textContent = t[key];
      });
      document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-html');
        if (t[key] !== undefined) el.innerHTML = t[key];
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-placeholder');
        if (t[key] !== undefined) el.placeholder = t[key];
      });

      var lc = document.getElementById('langCurrent');
      var lo = document.getElementById('langOther');
      var ml = document.getElementById('mobileLangLabel');
      if (lc) lc.textContent = l.toUpperCase();
      if (lo) lo.textContent = l === 'nl' ? 'EN' : 'NL';
      if (ml) ml.textContent = l === 'nl' ? 'NL / EN' : 'EN / NL';
      document.documentElement.lang = l;
      document.documentElement.removeAttribute('data-lang-loading');
    }

    // Apply non-default language on load
    if (lang !== 'nl') applyLang(lang);

    function toggleLang() { applyLang(lang === 'nl' ? 'en' : 'nl'); }
    var lb = document.getElementById('langToggle');
    var mlb = document.getElementById('mobileLangToggle');
    if (lb) lb.addEventListener('click', toggleLang);
    if (mlb) mlb.addEventListener('click', toggleLang);

    /* ===== SERVICES DROPDOWN (hover + click) ===== */
    var servicesGroup = document.querySelector('.services-group');
    var servicesDropdown = servicesGroup ? servicesGroup.querySelector('.services-dropdown') : null;

    if (servicesGroup && servicesDropdown) {
      servicesGroup.addEventListener('mouseenter', function() {
        servicesDropdown.style.opacity = '1';
        servicesDropdown.style.visibility = 'visible';
      });
      servicesGroup.addEventListener('mouseleave', function() {
        servicesDropdown.style.opacity = '0';
        servicesDropdown.style.visibility = 'hidden';
      });
      // Also support click toggle for accessibility
      var servicesBtn = servicesGroup.querySelector('.nav-services-btn');
      if (servicesBtn) {
        servicesBtn.addEventListener('click', function(e) {
          var isVisible = servicesDropdown.style.visibility === 'visible';
          servicesDropdown.style.opacity = isVisible ? '0' : '1';
          servicesDropdown.style.visibility = isVisible ? 'hidden' : 'visible';
        });
      }
      // Close on outside click
      document.addEventListener('click', function(e) {
        if (!servicesGroup.contains(e.target)) {
          servicesDropdown.style.opacity = '0';
          servicesDropdown.style.visibility = 'hidden';
        }
      });
    }

    /* ===== MOBILE MENU ===== */
    var menuBtn = document.getElementById('mobileMenuBtn');
    var mobileMenu = document.getElementById('mobileMenu');
    var hamburgerIcon = document.getElementById('hamburgerIcon');
    var mobileServicesBtn = document.getElementById('mobileServicesBtn');
    var mobileServicesDropdown = document.getElementById('mobileServicesDropdown');
    var mobileServicesArrow = document.getElementById('mobileServicesArrow');

    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', function() {
        var isOpen = !mobileMenu.classList.contains('hidden');
        if (isOpen) {
          mobileMenu.classList.add('hidden');
          if (hamburgerIcon) hamburgerIcon.textContent = 'menu';
        } else {
          mobileMenu.classList.remove('hidden');
          if (hamburgerIcon) hamburgerIcon.textContent = 'close';
        }
      });
    }

    if (mobileServicesBtn && mobileServicesDropdown) {
      mobileServicesBtn.addEventListener('click', function() {
        var isOpen = !mobileServicesDropdown.classList.contains('hidden');
        if (isOpen) {
          mobileServicesDropdown.classList.add('hidden');
          if (mobileServicesArrow) mobileServicesArrow.style.transform = '';
        } else {
          mobileServicesDropdown.classList.remove('hidden');
          if (mobileServicesArrow) mobileServicesArrow.style.transform = 'rotate(180deg)';
        }
      });
    }

    /* ===== NAV SCROLL BEHAVIOR ===== */
    var nav = document.getElementById('mainNav');
    if (!nav) return;
    var heroMode = nav.dataset.hero === 'true';
    var navLinks = nav.querySelectorAll('.nav-link');
    var logo = nav.querySelector('.logo-text');
    var cta = document.getElementById('navCta');
    var hIcon = document.getElementById('hamburgerIcon');
    var lt = document.getElementById('langToggle');

    if (!heroMode) {
      nav.style.background = 'rgba(255,255,255,0.88)';
      nav.style.backdropFilter = 'blur(16px)';
      nav.style.borderBottom = '1px solid rgba(0,0,0,0.08)';
      return;
    }

    function updateNav() {
      var scrolled = window.scrollY > window.innerHeight * 0.75;
      if (scrolled) {
        nav.style.background = 'rgba(255,255,255,0.88)';
        nav.style.backdropFilter = 'blur(16px)';
        nav.style.boxShadow = '0 1px 0 rgba(0,0,0,0.08)';
        navLinks.forEach(function(l) { l.style.color = '#1a1c1c'; });
        if (logo) logo.style.color = '#1a1c1c';
        if (cta) { cta.style.background = '#000000'; cta.style.color = '#ffffff'; cta.style.borderColor = '#000000'; }
        if (hIcon) hIcon.style.color = '#1a1c1c';
        if (lt) lt.style.color = '#1a1c1c';
      } else {
        nav.style.background = 'transparent';
        nav.style.backdropFilter = 'none';
        nav.style.boxShadow = 'none';
        navLinks.forEach(function(l) { l.style.color = '#ffffff'; });
        if (logo) logo.style.color = '#ffffff';
        if (cta) { cta.style.background = 'transparent'; cta.style.color = '#ffffff'; cta.style.borderColor = 'rgba(255,255,255,0.25)'; }
        if (hIcon) hIcon.style.color = '#ffffff';
        if (lt) lt.style.color = '#ffffff';
      }
    }

    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

  })();
  </script>

