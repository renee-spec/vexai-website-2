---
export interface Props {
  title: string;
  description?: string;
  heroPage?: boolean;
  bodyBg?: string;
  ogImage?: string;
}
const {
  title,
  description = 'Vexai bouwt intelligente AI-assistenten die jouw klantcontact overnemen — via chat, WhatsApp en telefoon. Altijd bereikbaar. Nooit offline.',
  heroPage = false,
  bodyBg = '#ffffff',
  ogImage = 'https://www.vexai.nl/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://www.vexai.nl');
---
<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph (social sharing + Google rich results) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Vexai" />
  <meta property="og:locale" content="nl_NL" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <!-- Favicon -->
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fustat:wght@400;700&family=Geist:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
  <script is:inline>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface":                "#f9f9f9",
            "surface-bright":         "#f9f9f9",
            "surface-variant":        "#e2e2e2",
            "surface-container":      "#eeeeee",
            "surface-container-low":  "#f3f3f3",
            "surface-container-high": "#e8e8e8",
            "surface-container-highest":"#e2e2e2",
            "surface-container-lowest":"#ffffff",
            "surface-dim":            "#dadada",
            "on-surface":             "#1a1c1c",
            "on-surface-variant":     "#444748",
            "outline":                "#747878",
            "outline-variant":        "#c4c7c7",
            "background":             "#f9f9f9",
            "primary":                "#000000",
            "primary-container":      "#1c1b1b",
            "on-primary":             "#ffffff",
            "on-primary-container":   "#858383",
            "secondary-auralis":      "#666666",
            "on-secondary":           "#ffffff",
            "secondary":              "#5e5e5e",
            "primary-orange":         "#ff571c",
            "tertiary":               "#000000",
            "on-tertiary":            "#ffffff",
            "error":                  "#ba1a1a",
            "inverse-surface":        "#2f3131",
            "inverse-on-surface":     "#f0f1f1",
          },
          fontFamily: {
            "body":       ["Inter", "Geist", "sans-serif"],
            "body-md":    ["Inter", "Geist", "sans-serif"],
            "body-lg":    ["Inter", "Geist", "sans-serif"],
            "h1":         ["Geist", "Inter", "sans-serif"],
            "h2":         ["Geist", "Inter", "sans-serif"],
            "h3":         ["Geist", "Inter", "sans-serif"],
            "button":     ["Geist", "Inter", "sans-serif"],
            "label-caps": ["Geist", "Inter", "sans-serif"],
            "headline-md":["Geist", "sans-serif"],
            "headline-lg":["Geist", "sans-serif"],
            "display-xl": ["Geist", "sans-serif"],
            "display-xl-mobile":["Geist", "sans-serif"],
            "label-md":   ["Geist", "sans-serif"],
          },
          fontSize: {
            "body":       ["17px",  { lineHeight:"1.6",  letterSpacing:"0em",    fontWeight:"400" }],
            "body-md":    ["16px",  { lineHeight:"1.5",  letterSpacing:"0",      fontWeight:"400" }],
            "body-lg":    ["18px",  { lineHeight:"1.6",  letterSpacing:"-0.01em",fontWeight:"400" }],
            "h1":         ["84px",  { lineHeight:"0.95", letterSpacing:"-0.04em",fontWeight:"600" }],
            "h2":         ["48px",  { lineHeight:"1.1",  letterSpacing:"-0.02em",fontWeight:"600" }],
            "h3":         ["28px",  { lineHeight:"1.2",  letterSpacing:"-0.01em",fontWeight:"500" }],
            "button":     ["14px",  { lineHeight:"1.0",  letterSpacing:"0.01em", fontWeight:"500" }],
            "label-caps": ["12px",  { lineHeight:"1.0",  letterSpacing:"0.05em", fontWeight:"600" }],
            "label-md":   ["14px",  { lineHeight:"20px", letterSpacing:"0.05em", fontWeight:"500" }],
            "headline-md":["32px",  { lineHeight:"40px", letterSpacing:"-0.01em",fontWeight:"600" }],
            "headline-lg":["40px",  { lineHeight:"48px", letterSpacing:"-0.02em",fontWeight:"600" }],
            "display-xl": ["72px",  { lineHeight:"80px", letterSpacing:"-0.04em",fontWeight:"700" }],
            "display-xl-mobile":["44px",{ lineHeight:"48px",letterSpacing:"-0.02em",fontWeight:"700"}],
          },
          animation: {
            "marquee": "marquee 40s linear infinite",
          },
          keyframes: {
            "marquee": { "0%": { transform:"translateX(0)" }, "100%": { transform:"translateX(-50%)" } },
          },
        }
      }
    }
  </script>
  <!-- Prevent i18n flash: hide translatable elements before page paints if lang=en -->
  <script is:inline>
    (function(){try{var l=localStorage.getItem('vexai_lang');if(l&&l!=='nl')document.documentElement.setAttribute('data-lang-loading','');}catch(e){}})();
  </script>
  <style is:inline>
    html[data-lang-loading] [data-i18n],
    html[data-lang-loading] [data-i18n-html] { visibility: hidden; }
  </style>
  <slot name="head" />
  <style is:inline>
    *, *::before, *::after { box-sizing: border-box; }
    body { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; margin: 0; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    /* Responsive heading tokens */
    @media (max-width: 767px) {
      .text-h1 { font-size: 42px !important; line-height: 1.1 !important; letter-spacing: -0.03em !important; }
      .text-h2 { font-size: 28px !important; line-height: 1.15 !important; letter-spacing: -0.02em !important; }
      .text-headline-lg { font-size: 28px !important; line-height: 1.2 !important; }
      .text-headline-md { font-size: 22px !important; line-height: 1.25 !important; }
      .text-display-xl { font-size: 44px !important; line-height: 1.1 !important; }
    }
    /* Services dropdown */
    .services-dropdown { pointer-events: none; }
    .services-group:hover .services-dropdown { pointer-events: auto; }
    /* Mobile menu transition */
    #mobileMenu { overflow: hidden; }
  </style>
</head>
<body style={`background-color:${bodyBg};`}>

  <!-- NAVIGATION -->
  <nav
    id="mainNav"
    data-hero={heroPage ? "true" : undefined}
    class="fixed top-0 w-full z-50 transition-all duration-300"
    style="background: transparent;"
  >
    <div class="max-w-[1280px] mx-auto px-5 md:px-8 flex justify-between items-center h-[68px] md:h-[72px]">

      <!-- Left: Logo + Desktop Links -->
      <div class="flex items-center gap-6 md:gap-10">
        <a href="/" class="nav-logo text-[20px] font-bold tracking-tighter flex-shrink-0" style={heroPage ? "color:#ffffff" : "color:#1a1c1c"}>
          <span style="color:#ff5518">_</span><span class="logo-text">Vexai</span>
        </a>

        <!-- Desktop nav links -->
        <div class="hidden md:flex items-center gap-6">
          <!-- Services dropdown -->
          <div class="relative services-group">
            <button
              class="nav-link text-[14px] font-medium tracking-tight transition-colors duration-200 hover:opacity-70 flex items-center gap-0.5 bg-transparent border-0 cursor-pointer p-0 nav-services-btn"
              style={heroPage ? "color:#ffffff" : "color:#1a1c1c"}
            >
              <span data-i18n="nav.services">Services</span>
              <span class="material-symbols-outlined text-[18px] transition-transform duration-200 nav-services-arrow" style="line-height:1;margin-top:1px;">expand_more</span>
            </button>
            <!-- Dropdown panel -->
            <div class="services-dropdown absolute top-full left-0 mt-3 bg-white rounded-2xl shadow-xl border border-outline-variant py-2 opacity-0 group-hover:opacity-100 invisible min-w-[160px] z-50 transition-all duration-200"
              style="transition:opacity 0.15s ease,visibility 0.15s ease;">
              <a href="/chat-ai/" class="flex items-center px-4 py-2.5 text-[14px] text-on-surface hover:bg-surface-container transition-colors" data-i18n="nav.chat_ai">Chat AI</a>
              <a href="/telefoon-ai/" class="flex items-center px-4 py-2.5 text-[14px] text-on-surface hover:bg-surface-container transition-colors" data-i18n="nav.phone_ai">Telefoon AI</a>
            </div>
          </div>
          <a href="/prijzen/" class="nav-link text-[14px] font-medium tracking-tight transition-colors duration-200 hover:opacity-70" style={heroPage ? "color:#ffffff" : "color:#1a1c1c"} data-i18n="nav.pricing">Prijzen</a>
          <a href="/contact/" class="nav-link text-[14px] font-medium tracking-tight transition-colors duration-200 hover:opacity-70" style={heroPage ? "color:#ffffff" : "color:#1a1c1c"} data-i18n="nav.contact">Contact</a>
        </div>
      </div>

      <!-- Right: Lang toggle + CTA + Hamburger -->
      <div class="flex items-center gap-2 md:gap-3">
        <!-- Language toggle (desktop) -->
        <button
          id="langToggle"
          class="hidden md:flex items-center text-[12px] font-medium opacity-50 hover:opacity-100 transition-opacity"
          style={heroPage ? "color:#ffffff" : "color:#1a1c1c"}
          aria-label="Switch language"
        >
          <span id="langCurrent">NL</span><span class="mx-1 opacity-40">/</span><span id="langOther">EN</span>
        </button>

        <!-- CTA button (desktop) -->
        <a
          id="navCta"
          href="/contact/"
          data-i18n="nav.cta"
          style={heroPage
            ? "background:transparent;color:#ffffff;border:1px solid rgba(255,255,255,0.25);transition:all 0.3s ease;"
            : "background:#000000;color:#ffffff;border:1px solid #000000;transition:all 0.3s ease;"}
          class="hidden md:flex px-5 py-2.5 rounded-full text-[14px] font-medium whitespace-nowrap items-center"
        >
          Plan een adviesgesprek
        </a>

        <!-- Hamburger (mobile only) -->
        <button
          id="mobileMenuBtn"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded-full transition-colors"
          aria-label="Menu openen"
        >
          <span class="material-symbols-outlined text-[24px] nav-hamburger" id="hamburgerIcon" style={heroPage ? "color:#ffffff" : "color:#1a1c1c"}>menu</span>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobileMenu" class="hidden md:hidden bg-white border-t border-outline-variant shadow-lg">
      <div class="px-5 py-3 flex flex-col">
        <!-- Services accordion -->
        <div class="border-b border-outline-variant">
          <button id="mobileServicesBtn" class="w-full flex items-center justify-between py-3.5 text-[15px] font-medium text-on-surface">
            <span data-i18n="nav.services">Services</span>
            <span class="material-symbols-outlined text-[18px] transition-transform duration-200" id="mobileServicesArrow">expand_more</span>
          </button>
          <div id="mobileServicesDropdown" class="hidden pb-3 pl-3 flex flex-col gap-1">
            <a href="/chat-ai/" class="py-2 text-[14px] text-on-surface-variant hover:text-on-surface transition-colors block" data-i18n="nav.chat_ai">Chat AI</a>
            <a href="/telefoon-ai/" class="py-2 text-[14px] text-on-surface-variant hover:text-on-surface transition-colors block" data-i18n="nav.phone_ai">Telefoon AI</a>
          </div>
        </div>
        <a href="/prijzen/" class="py-3.5 text-[15px] font-medium text-on-surface border-b border-outline-variant" data-i18n="nav.pricing">Prijzen</a>
        <a href="/contact/" class="py-3.5 text-[15px] font-medium text-on-surface border-b border-outline-variant" data-i18n="nav.contact">Contact</a>
        <!-- Bottom row -->
        <div class="pt-4 pb-2 flex items-center justify-between gap-3">
          <a href="/contact/" class="flex-1 bg-primary text-white py-3 rounded-full text-[14px] font-medium text-center" data-i18n="nav.cta">Plan een adviesgesprek</a>
          <button id="mobileLangToggle" class="text-[12px] font-semibold text-on-surface-variant hover:text-on-surface transition-colors px-3 py-3 border border-outline-variant rounded-full whitespace-nowrap" aria-label="Wissel taal">
            <span id="mobileLangLabel">NL / EN</span>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- PAGE CONTENT -->
  <slot />

  <!-- FOOTER -->
  <footer class="w-full border-t border-zinc-200 bg-white pt-14 md:pt-20 pb-10 md:pb-12">
    <div class="max-w-[1280px] mx-auto px-5 md:px-8">
      <div class="grid grid-cols-2 md:grid-cols-12 gap-8 md:gap-12 mb-12 md:mb-16">
        <!-- Brand column -->
        <div class="col-span-2 md:col-span-4 flex flex-col gap-5">
          <div class="text-[22px] font-bold tracking-tighter text-zinc-900">
            <span style="color:#ff5518">_</span>Vexai
          </div>
          <p class="text-sm text-zinc-500 max-w-xs" data-i18n="footer.tagline">Slimme AI-assistenten die jouw bedrijf laten groeien.</p>
          <div class="flex flex-col gap-3 mt-1">
            <label class="text-sm font-semibold text-zinc-900" data-i18n="footer.newsletter">Blijf op de hoogte</label>
            <form class="flex gap-2">
              <input type="email" data-i18n-placeholder="footer.email_placeholder" placeholder="E-mailadres" class="flex-grow min-w-0 px-4 py-2 rounded-full border border-zinc-200 bg-white text-sm focus:outline-none focus:border-black transition-colors" />
              <button type="submit" class="bg-black text-white px-4 py-2 rounded-full text-sm font-medium hover:opacity-90 transition-all whitespace-nowrap flex-shrink-0" data-i18n="footer.subscribe">Inschrijven</button>
            </form>
          </div>
        </div>
        <!-- Product -->
        <div class="md:col-span-2 md:col-start-6 flex flex-col gap-3">
          <h4 class="text-xs font-semibold text-zinc-900 uppercase tracking-widest mb-1" data-i18n="footer.col_product">Product</h4>
          <a href="/chat-ai/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="nav.chat_ai">Chat AI</a>
          <a href="/telefoon-ai/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="nav.phone_ai">Telefoon AI</a>
          <a href="/prijzen/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="nav.pricing">Prijzen</a>
        </div>
        <!-- Company -->
        <div class="md:col-span-2 flex flex-col gap-3">
          <h4 class="text-xs font-semibold text-zinc-900 uppercase tracking-widest mb-1" data-i18n="footer.col_company">Bedrijf</h4>
          <a href="/over-ons/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="footer.about">Over ons</a>
          <a href="/blog/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="footer.blog">Blog</a>
          <a href="/vacatures/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="footer.jobs">Vacatures</a>
          <a href="/contact/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="nav.contact">Contact</a>
        </div>
        <!-- Legal -->
        <div class="md:col-span-2 flex flex-col gap-3">
          <h4 class="text-xs font-semibold text-zinc-900 uppercase tracking-widest mb-1" data-i18n="footer.col_legal">Juridisch</h4>
          <a href="/privacy/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="footer.privacy">Privacy</a>
          <a href="/voorwaarden/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="footer.terms">Voorwaarden</a>
          <a href="/beveiliging/" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors" data-i18n="footer.security">Beveiliging</a>
        </div>
      </div>
      <div class="pt-6 border-t border-zinc-200 flex flex-col md:flex-row justify-between items-center gap-4">
        <span class="text-xs text-zinc-400" data-i18n="footer.copyright">© 2025-2026 _Vexai. Alle rechten voorbehouden.</span>
        <div class="flex gap-5 text-zinc-400">
          <a href="#" class="hover:text-zinc-900 transition-colors"><span class="material-symbols-outlined text-[20px]">language</span></a>
          <a href="#" class="hover:text-zinc-900 transition-colors"><span class="material-symbols-outlined text-[20px]">chat</span></a>
        </div>
      </div>
    </div>
  </footer>

  <!-- SCRIPTS: I18N + MOBILE MENU + NAV SCROLL -->
  <script is:inline>
  (function() {

    /* ===== I18N TRANSLATIONS ===== */
    var T = {
      nl: {
        'nav.services': 'Services',
        'nav.chat_ai': 'Chat AI',
        'nav.phone_ai': 'Telefoon AI',
        'nav.pricing': 'Prijzen',
        'nav.contact': 'Contact',
        'nav.cta': 'Plan een adviesgesprek',
        'footer.tagline': 'Slimme AI-assistenten die jouw bedrijf laten groeien.',
        'footer.newsletter': 'Blijf op de hoogte',
        'footer.email_placeholder': 'E-mailadres',
        'footer.subscribe': 'Inschrijven',
        'footer.col_product': 'Product',
        'footer.col_company': 'Bedrijf',
        'footer.col_legal': 'Juridisch',
        'footer.about': 'Over ons',
        'footer.blog': 'Blog',
        'footer.jobs': 'Vacatures',
        'footer.privacy': 'Privacy',
        'footer.terms': 'Voorwaarden',
        'footer.security': 'Beveiliging',
        'footer.copyright': '© 2025-2026 _Vexai. Alle rechten voorbehouden.',
